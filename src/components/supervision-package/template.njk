{% set standardAppointmentsComplete = params.currentYear.appointments.allowance is defined and params.currentYear.appointments.completed is defined and (params.currentYear.appointments.completed | int) >= (params.currentYear.appointments.allowance| int) %}
{% set hasSpecialStatus = params.inputs.offenderPersonalDisorderPathway or params.isInBreach or params.isCustody or params.inputs.integratedOffenderManagementRedRated %}

<div class='govuk-width-container supervision-package'>
    {% if standardAppointmentsComplete or hasSpecialStatus %}
    <div class='app-tier-header'>
        <h2 class='govuk-heading-m govuk-!-margin-bottom-0'>{{ 'Supervision package: ' ~ params.sentenceType if params.sentenceType else 'Supervision package' }}</h2>
        {% include './partials/_tags.njk' %}
    </div>
    {% else %}
            <h2 class='govuk-heading-m'>{{ 'Supervision package: ' ~ params.sentenceType if params.sentenceType else 'Supervision package' }}</h2>
    {% endif %}

    <div class='govuk-grid-row'>
        <div class='{{ "govuk-grid-column-one-half" if params.phase.name.description else "govuk-grid-column-two-thirds" }}'>
            <div class='app-tier-header'>
                <h3 class='govuk-heading-s govuk-!-margin-bottom-0'>
                    Tier {{ '' if params.tierScore == 'MISSING' else params.tierScore }}
                </h3>
                {% if params.tag.text and params.tag.color %}
                    <strong class='govuk-tag govuk-tag--{{ params.tag.color }}'>{{ params.tag.text }}</strong>
                {% endif %}
            </div>

            {% if params.createdOn %}
                <p class='govuk-body'>The supervision package was created on {{ params.createdOn }}.</p>
            {% endif %}

            {% if params.tag.text == 'Provisional' %}
                <p class='govuk-body'>
                    We will calculate the supervision package once the tier is confirmed.
                </p>
            {% endif %}

            {% if params.tag.text == 'Unavailable' %}
                <p class='govuk-body'>
                    Tier information is currently unavailable.
                </p>
            {% endif %}

            {% if params.historyHref %}
                <p class='govuk-body'>
                    <a href='{{ params.historyHref }}' class='govuk-link govuk-link--no-visited-state'>
                        {{ params.historyText or 'View tier change history' }}
                    </a>
                </p>
            {% endif %}

            {% if params.nextAppointment and params.nextAppointmentHref %}
                <h3 class='govuk-heading-s'>Next appointment</h3>
                <p class='govuk-body'>
                    <a href='{{ params.nextAppointmentHref }}' class='govuk-link govuk-link--no-visited-state'>{{ params.nextAppointment }}</a>
                </p>
            {% endif %}
        </div>

        {% if params.phase.name.description %}
            <div class='govuk-grid-column-one-half'>
                <h3 class='govuk-heading-s'>{{ params.phase.name.description | toTitleCase }} stage</h3>
                {% if params.phase.name.code  == 'INIT' %}
                    {% include './partials/_early-engagement.njk' %}
                {% endif %}
            </div>
        {% endif %}
    </div>

    {% if params.arrangeAppointmentHref or (params.crn and params.deliusBaseURL) %}
        <div class='govuk-button-group'>
            {% if params.arrangeAppointmentHref %}
                <a href='{{ params.arrangeAppointmentHref }}' role='button' draggable='false' class='govuk-button' data-module='govuk-button'>
                    Arrange an appointment
                </a>
            {% endif %}

            {% if params.crn and params.deliusBaseURL %}
                <a href='{{ params.deliusBaseURL }}/NDelius-war/delius/JSP/deeplink.xhtml?component=RegisterSummary&CRN={{params.crn}}' role='button' draggable='false' class='govuk-button govuk-button--secondary' data-module='govuk-button'>
                    Update NDelius risk flag
                </a>
            {% endif %}
        </div>
    {% endif %}
</div>
