
{% set phaseLengthMonths = gestPackageLength(params.phaseDates.startDate, params.phaseDates.endDate) %}
<p class='govuk-body'>{{ params.firstName }} has {{ params.appointmentsRemaining }} supervision appointments remaining
    until the supervision stage {{ 'ends' if phaseLengthMonths <= 12 else 'resets' }} on {{ params.supervisionPhaseEndDate }}.
</p>

{% if params.finalThirdStartDate %}
    <p class='govuk-body'>{{ params.firstName }} is eligible to start the final third stage on
        {{ params.finalThirdStartDate }}
    </p>
{% endif %}
<p class='govuk-body'>
    {{ params.appointmentsAttended }} of {{ params.appoitmentsTotal }} used
</p>
