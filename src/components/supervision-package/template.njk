{% from 'govuk/components/button/macro.njk' import govukButton %}

<div class='govuk-width-container supervision-package'>
    <h2 class='govuk-heading-m'>{{ 'Supervision package: ' + params.heading if params.heading else 'Supervision package' }}</h2>
    <div class='govuk-grid-row'>
        <div class='govuk-grid-column-one-half'>
            <div class='app-tier-header'>
                <h3 class='govuk-heading-s govuk-!-margin-bottom-0'>
                    Tier {{ '' if params.tierScore == 'MISSING' else params.tierScore }}
                </h3>

                {% if params.tag.text and params.tag.color %}
                    <strong class='govuk-tag govuk-tag--{{ params.tag.color }}'>{{ params.tag.text }}</strong>
                {% endif %}
            </div>

            {% if params.createdOn %}
                <p class='govuk-body'>The supervision package was created on {{ params.createdOn }}.</p>
            {% endif %}

            {% if params.tag.text == 'Provisional' %}
                <p class='govuk-body'>
                    We will calculate the supervision package once the tier is confirmed.
                </p>
            {% endif %}

            {% if params.tag.text == 'Unavailable' %}
                <p class='govuk-body'>
                    Tier information is currently unavailable.
                </p>
            {% endif %}

            {% if params.historyHref %}
                <p class='govuk-body'>
                    <a href='{{ params.historyHref }}' class='govuk-link govuk-link--no-visited-state'>
                        {{ params.historyText or 'View tier change history' }}
                    </a>
                </p>
            {% endif %}

            {% if params.nextAppointment %}
                <h3 class='govuk-heading-s'>Next appointment</h3>
                <p class='govuk-body'>
                    <a href='{{ params.nextAppointmentHref }}' class='govuk-link govuk-link--no-visited-state'>{{ params.nextAppointment }}</a>
                </p>
            {% endif %}
        </div>

        <div class='govuk-grid-column-one-half'>
            <h3 class='govuk-heading-s' >{{ params.phase.phaseName }} stage</h3>
            {% if params.phase.phaseName == 'Early engagement'%}
                {% include './partials/_early-engagement-stage.njk' %}
            {% elseif params.phase.phaseName == 'Supervision engagement' %}
                {% include './partials/_supervision-stage.njk'  %}
            {% elseif params.phase.phaseName == 'Final third' %}
                {% include './partials/_final-third-stage.njk' %}
            {% else %}
                <p class='govuk-body'>{{ params.popName }} has {{params.appointments.allowance - params.appointments.completed}} supervision appointments remaining until the {{ params.phase.phaseName }} ends on the {{ params.phase.endDate }}</p>
            {% endif %}

            {% include './partials/_progress-bar.njk' %}

            <div class='govuk-grid-row govuk-!-margin-top-4'>
                <div class='govuk-grid-column-one-third'>
                    <p class='govuk-body govuk-!-margin-bottom-2'>Maximum</p>
                    <p class='govuk-body-l govuk-!-font-weight-bold'>{{params.appointments.allowance}}</p>
                </div>
                <div class='govuk-grid-column-one-third'>
                    <p class='govuk-body govuk-!-margin-bottom-2'>Remaining</p>
                    <p class='govuk-body-l govuk-!-font-weight-bold'>{{params.appointments.allowance - params.appointments.completed}}</p>
                </div>
                <div class='govuk-grid-column-one-third'>
                    <p class='govuk-body govuk-!-margin-bottom-2'>Upcoming</p>
                    <p class='govuk-body-l govuk-!-font-weight-bold'>{{params.appointments.scheduled}}</p>
                </div>
            </div>

            <p class='govuk-body'>
                {% if params.supervisionPhase == 'Final Third '%}
                    <a href='#' class='govuk-link govuk-link--no-visited-state'>{{ 'View final third contact' if params.supervisionPhase == 'Supervision engagement'}}View final third contact</a>
                {% else %}
                    <a class='govuk-link govuk-link--no-visited-state' href='#'>View all appointments</a>
                {% endif %}
            </p>
        </div>
    </div>

    <div class='govuk-button-group'>
        {{ govukButton({
            text: 'Arrange an appointment',
            href: '#'
        }) }}

        {{ govukButton({
            text: 'Update NDelius risk flag',
            classes: 'govuk-button--secondary',
            href: '#'
        }) }}
    </div>
</div>
